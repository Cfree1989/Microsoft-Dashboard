      - galStatusTabs:
          Control: Gallery@2.15.0
          Variant: Horizontal
          Properties:
            BorderColor: =RGBA(0, 18, 107, 1)
            FocusedBorderThickness: =varFocusedBorderThickness
            Height: =55
            Items: |-
              =Table(
                  {Status: "Uploaded", Color: varColorPrimary},
                  {Status: "Pending", Color: RGBA(255, 185, 0, 1)},
                  {Status: "Ready to Print", Color: varColorSuccess},
                  {Status: "Printing", Color: varColorWarning},
                  {Status: "Completed", Color: varColorPrimary},
                  {Status: "Paid & Picked Up", Color: varColorSuccess},
                  {Status: "Rejected", Color: varColorDanger},
                  {Status: "Canceled", Color: RGBA(138, 136, 134, 1)},
                  {Status: "Archived", Color: RGBA(96, 94, 92, 1)}
              )
            TemplatePadding: =3
            TemplateSize: =varTabGalleryHeight
            Transition: =Transition.Push
            Width: =Parent.Width
            Y: =55
          Children:
            - btnStatusTab:
                Control: Classic/Button@2.2.0
                Properties:
                  BorderColor: =varInputBorderColor
                  BorderThickness: =1
                  Color: |-
                    =If(
                        varSelectedStatus = ThisItem.Status, 
                        If(ThisItem.Status = "Pending", Color.Black, Color.White),
                        varColorText
                    )
                  DisabledBorderColor: =RGBA(166, 166, 166, 1)
                  Fill: =If(varSelectedStatus = ThisItem.Status, ThisItem.Color, RGBA(245, 245, 245, 1))
                  FocusedBorderColor: =varInputBorderColor
                  FocusedBorderThickness: =varFocusedBorderThickness
                  Font: =varAppFont
                  HoverBorderColor: =ColorFade(Self.BorderColor, 20%)
                  HoverColor: =If(varSelectedStatus = ThisItem.Status, If(ThisItem.Status = "Pending", Color.Black, Color.White), varColorText)
                  HoverFill: =ColorFade(If(varSelectedStatus = ThisItem.Status, ThisItem.Color, RGBA(245, 245, 245, 1)), -10%)
                  OnSelect: =Set(varSelectedStatus, ThisItem.Status)
                  PressedBorderColor: =Self.Fill
                  PressedColor: =If(varSelectedStatus = ThisItem.Status, If(ThisItem.Status = "Pending", Color.Black, Color.White), varColorText)
                  PressedFill: =ColorFade(If(varSelectedStatus = ThisItem.Status, ThisItem.Color, RGBA(245, 245, 245, 1)), -20%)
                  Size: =10
                  Text: =ThisItem.Status & " " & Text(CountRows(Filter(PrintRequests, Status.Value = ThisItem.Status)))
                  Width: =141
                  X: =5
                  Y: =4
      - lblEmptyState:
          Control: Label@2.5.1
          Properties:
            Align: =Align.Center
            BorderColor: =RGBA(0, 18, 107, 1)
            Color: =varColorTextLight
            Font: =varAppFont
            Height: =100
            Size: =14
            Text: ="No " & varSelectedStatus & " requests found"
            Visible: =CountRows(galJobCards.AllItems) = 0
            Width: =400
            X: =(Parent.Width - 400) / 2
            Y: =350
      - galJobCards:
          Control: Gallery@2.15.0
          Variant: Vertical
          Properties:
            BorderColor: =RGBA(0, 18, 107, 1)
            Height: =Parent.Height - 160
            Items: |-
              =SortByColumns(
                  Filter(
                      PrintRequests,
                      // Filter by selected status tab (use .Value for Choice fields)
                      Status.Value = varSelectedStatus,
                      // Search filter (searches name and email)
                      If(
                          IsBlank(varSearchText), 
                          true, 
                          varSearchText in Student.DisplayName || varSearchText in StudentEmail || varSearchText in ReqKey
                      ),
                      // Needs attention filter
                      If(varNeedsAttention, NeedsAttention = true, true)
                  ),
                  "NeedsAttention", SortOrder.Descending,  // Attention items first (true > false)
                  "Created", SortOrder.Ascending            // Then oldest first (longest in queue)
              )
            TemplatePadding: =8
            TemplateSize: =varCardGalleryHeight
            Width: =Parent.Width
            WrapCount: =4
            Y: =160
          Children:
            - recCardBackground:
                Control: Rectangle@2.3.0
                Properties:
                  BorderColor: |-
                    =If(
                        varBatchSelectMode && ThisItem.ID in colBatchItems.ID,
                        varColorSuccess,  // Green border for selected batch items
                        If(ThisItem.NeedsAttention && ThisItem.Status.Value <> "Uploaded", RGBA(255, 180, 0, 1), varColorBorderLight)
                    )
                  BorderThickness: =If(ThisItem.NeedsAttention && ThisItem.Status.Value <> "Uploaded", 2, 1)
                  Fill: =If(varBatchSelectMode && ThisItem.ID in colBatchItems.ID, RGBA(220, 240, 220, 1), If(ThisItem.NeedsAttention && ThisItem.Status.Value <> "Uploaded", RGBA(255, 235, 180, 1), varColorBgCard))
                  Height: =Parent.TemplateHeight - 8
                  OnSelect: |-
                    =If(
                        varBatchSelectMode && ThisItem.Status.Value = "Completed",
                        // Batch mode: toggle item in collection
                        If(
                            ThisItem.ID in colBatchItems.ID,
                            Remove(colBatchItems, LookUp(colBatchItems, ID = ThisItem.ID)),
                            Collect(colBatchItems, ThisItem)
                        ),
                        // Normal mode: select item for details (no action needed here - buttons handle modals)
                        Set(varSelectedItem, ThisItem)
                    )
                  Width: =Parent.TemplateWidth
                  Y: =8
            - lblStudentName:
                Control: Label@2.5.1
                Properties:
                  BorderColor: =RGBA(0, 18, 107, 1)
                  Color: =varColorText
                  Font: =varAppFont
                  Height: =24
                  OnSelect: =Select(Parent)
                  Size: =14
                  Text: =ThisItem.Student.DisplayName
                  Width: =315
                  X: =12
                  Y: =14
            - lblSubmittedTime:
                Control: Label@2.5.1
                Properties:
                  Align: =Align.Right
                  BorderColor: =RGBA(0, 18, 107, 1)
                  Color: =varColorDanger
                  Font: =varAppFont
                  Height: =44
                  OnSelect: =Select(Parent)
                  Size: =8
                  Text: |-
                    =If(
                        DateDiff(ThisItem.Created, Now(), TimeUnit.Minutes) < 1,
                        "Just now",
                        "Submitted " &
                        If(
                            DateDiff(ThisItem.Created, Now(), TimeUnit.Days) > 0,
                            Text(DateDiff(ThisItem.Created, Now(), TimeUnit.Days)) & "d ",
                            ""
                        ) &
                        If(
                            Mod(DateDiff(ThisItem.Created, Now(), TimeUnit.Hours), 24) > 0,
                            Text(Mod(DateDiff(ThisItem.Created, Now(), TimeUnit.Hours), 24)) & "h ",
                            ""
                        ) &
                        Text(Mod(DateDiff(ThisItem.Created, Now(), TimeUnit.Minutes), 60)) & "m ago"
                    )
                  Width: =99
                  X: =200
                  Y: =8
            - lblFilename:
                Control: Label@2.5.1
