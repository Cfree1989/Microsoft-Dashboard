                            Email: User().Email,
                            JobTitle: "",
                            Picture: ""
                        }
                    });

                    'Flow-(C)-Action-LogAction'.Run(
                        Text(varCurrentItem.ID),      // RequestID
                        "Status Change",              // Action
                        "Status",                     // FieldName
                        "Printing",                   // NewValue
                        varMeEmail                    // ActorEmail
                    );

                    Notify("Print started!", NotificationType.Success);

                    // === HIDE LOADING ===
                    Set(varIsLoading, false);
                    Set(varLoadingMessage, "")
