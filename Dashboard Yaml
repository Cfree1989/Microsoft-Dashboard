      - galStatusTabs:
          Control: Gallery@2.15.0
          Variant: Horizontal
          Properties:
            BorderColor: =RGBA(0, 18, 107, 1)
            FocusedBorderThickness: =varFocusedBorderThickness
            Height: =55
            Items: |-
              =Table(
