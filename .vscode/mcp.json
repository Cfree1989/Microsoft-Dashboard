{
  "inputs": [
    {
      "type": "promptString",
      "id": "canvas-environment-id",
      "description": "Power Apps environment ID (from Studio URL path after /e/, e.g. Default-xxxx...)",
      "password": false
    },
    {
      "type": "promptString",
      "id": "canvas-app-id",
      "description": "Canvas app ID GUID (from Studio URL app-id=... last segment)",
      "password": false
    },
    {
      "type": "promptString",
      "id": "canvas-cluster-category",
      "description": "Cluster category: prod (make.powerapps.com / make.preview.powerapps.com) or test (other hostnames)",
      "password": false
    }
  ],
  "servers": {
    "canvas-authoring": {
      "type": "stdio",
      "command": "dnx",
      "args": [
        "Microsoft.PowerApps.CanvasAuthoring.McpServer",
        "--yes",
        "--prerelease",
        "--source",
        "https://api.nuget.org/v3/index.json"
      ],
      "env": {
        "CANVAS_ENVIRONMENT_ID": "${input:canvas-environment-id}",
        "CANVAS_APP_ID": "${input:canvas-app-id}",
        "CANVAS_CLUSTER_CATEGORY": "${input:canvas-cluster-category}"
      }
    }
  }
}

